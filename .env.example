# Copy to .env and fill in. Never commit .env.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Local dev defaults to SQLite if unset. For Postgres/PostGIS later:
# DATABASE_URL=postgis://user:pass@localhost:5432/lens
# DATABASE_URL=postgres://user:pass@localhost:5432/lens

BRAND_NAME=Lens
SITE_URL=http://localhost:8000

# Stripe — leave blank to use the built-in TEST payment gateway. Set these
# (and `pip install stripe`) to switch to real payments automatically.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Production only
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
