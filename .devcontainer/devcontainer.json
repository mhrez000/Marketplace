{
  "name": "Lens marketplace",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "postCreateCommand": "pip install -r requirements.txt && python manage.py migrate && python manage.py seed_demo",
  "postStartCommand": "nohup python manage.py runserver 0.0.0.0:8000 > /tmp/lens-server.log 2>&1 &",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Lens web",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
